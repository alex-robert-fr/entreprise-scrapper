# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Scraping APIs ──────────────────────────────────────
SIRENE_TOKEN=xxx
GOOGLE_MAPS_API_KEY=xxx

# ─── Database ───────────────────────────────────────────
# Local (docker-compose) : port 5433 pour éviter tout conflit avec un Postgres système
# Prod : fournie automatiquement par Railway
DATABASE_URL=postgresql://scraper:scraper@localhost:5433/scraper

# ─── Auth (Better Auth) ────────────────────────────────
# Générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=change-me
# URL publique de l'app (sans slash final)
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────
# Callback à configurer côté Google Cloud Console :
#   http://localhost:3000/api/auth/callback/google  (dev)
#   https://leadscraper.<tld>/api/auth/callback/google  (prod)
GOOGLE_OAUTH_CLIENT_ID=xxx
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# ─── Admin ─────────────────────────────────────────────
# Pour promouvoir un user en admin après signup :
#   UPDATE "user" SET role = 'admin' WHERE email = 'ton@email';

# ─── À venir (billing Polar) ────────────────────────────
# POLAR_API_KEY=xxx
# POLAR_WEBHOOK_SECRET=xxx
