# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Scraping APIs ──────────────────────────────────────
SIRENE_TOKEN=xxx
GOOGLE_MAPS_API_KEY=xxx

# ─── Database ───────────────────────────────────────────
# Local (docker-compose) : port 5433 pour éviter tout conflit avec un Postgres système
# Prod : fournie automatiquement par Railway
DATABASE_URL=postgresql://scraper:scraper@localhost:5433/scraper

# ─── À venir (#37 — Auth Better Auth) ───────────────────
# Générer avec : openssl rand -base64 32
# BETTER_AUTH_SECRET=xxx
# BETTER_AUTH_URL=http://localhost:3000

# ─── À venir (#37 — Google OAuth) ───────────────────────
# GOOGLE_OAUTH_CLIENT_ID=xxx
# GOOGLE_OAUTH_CLIENT_SECRET=xxx

